let x = #a(3l); match x {#b(c) -> -c | #a(c) -> c};;

let y = 3l; let x = #a(y); match x {#b(c) -> -c | #a(c) -> c};;

let x = #a(3l); match x {#b(c) -> -c | #a(c) -> 1};;

let x = #a(3); match x {#b(c) -> -c | #a(c) -> c};;

let x = #a(3); match x {#b(c) -> -c | #a(c) -> 1};;

let x = 1l; let y = 2l; let u = #a(3); match u {#b(c) -> -c + x | #a(c) -> c + y};;

type un = union {#num: int, #val: bool};
let x = 1l; let y = 2l; let f = lfn u:un =o {
    match u {
        #num(n) -> n > x
        | #val(b) -> b && (y > 2)
    }
};
f(#num(6));;

