let x = box 0; x++;;

let x = box 0; x++; *x;;

let x = box true; x++; *x;;

let x = box 0; x--;;

let x = box 0; x--; *x;;

let x = box true; x--; *x;;

let x = box 0; ++x;;

let x = box 0; ++x; *x;;

let x = box true; ++x; *x;;

let x = box 0; --x;;

let x = box 0; --x; *x;;

let x = box true; --x; *x;;
