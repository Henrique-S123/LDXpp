type un = union {#num: int, #txt: string, #val: bool};
let f = fn x:un => {
    match x {
        #num(n) -> n + 1
        | #txt(s) -> 2
        | #val(b) -> 3
        | #deadcode(d) -> println("should not come here")
    }
};
f(#val(true));;

type Opt = union { #none:(), #some:int};
let l0:Opt = #none(());
l0;;

type Opt = union { #none:(), #some:int};
let l0:Opt = #some(2);
l0;;

type Opt = union { #none:(), #some:int};
let l0:Opt = #none(());
match l0 {
    #none(_) -> 1
|   #some(i) -> i    
};;

type Opt = union { #none:(), #some:int};
let l0:Opt = #some(42);
match l0 {
    #none(_) -> 1
|   #some(i) -> i    
};;

type Opt = union { #none:(), #some:int};
let l0:Opt = #some(42);
match l0 {
    #none(_) -> 1
|   #some(i) -> i  
|   #never(_) -> true * false
};;

type Opt = union { #none:(), #some:int};
let l0:Opt = #some(42);
match l0 {
    #none(_) -> 1
|   #some(i) -> (i && true)  
};;

type Opt = union { #none:(), #some:int};
let l0:Opt = #some(42);
match l0 {
    #none(_) -> 1
|   #some(i) -> (i > 2)  
};;

type Opt = union { #none:(), #some:int};
let l0:Opt = #some(42);
match l0 {
    #none(_) -> 1
};;

type Opt = union { #none:(), #some:int};
let l0:Opt = #none(());
match l0 {
    #some(x) -> x + 1
};;

type Circle = pair(int&int);
type Rectangle = pair(int&int);
type Blob = union { #circle: Circle, #rect: Rectangle };
let r1 = #rect(10&20);
match r1 {
        #circle(c) -> let r = pi*(fst(c)); (r*r)/2
    |   #rect(r) -> (fst(r)) * (snd(r))
}
;;

type Circle = pair(int&int);
type Rectangle = pair(int&int);
type Blob = union { #circle: Circle, #rect: Rectangle };
let r1:Blob = #rect(10&20);
match r1 {
        #circle(c) -> let r = 3*(fst(c)); (r*r)/2
    |   #rect(r) -> (fst(r)) * (snd(r))
}
;;

type Circle = pair(int&int);
type Rectangle = pair(int&int);
type Blob = union { #circle: Circle, #rect: Rectangle };
let pi = 3142;
let area = fn b:Blob => {
  match b {
        #circle(c) -> let r = pi*(fst(c)); (r*r)/2
    |   #rect(r) -> (fst(r)) * (snd(r))
    }
};
let r1 = #rect(10&20);
area(r1);;

