let x = #a(3); match x {#b(c) -> -c | #a(c) -> c};;

let x = #a(3); match x {#b(c) -> -c | #d(c) -> c};;

type un = union {#num: int, #txt: string, #val: bool};
let f = fn x:un => {
    match x {
        #num(n) -> n + 1
        | #txt(s) -> s + ".txt"
        | #val(b) -> ~b
    }
};
f(#num(6));;

