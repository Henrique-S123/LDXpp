type NatL = linunion {$zero:(), $succ:NatL};
let nl0 = $zero(());
let nl1 = $succ(nl0);
let nl2 = $succ(nl1);
let ladd:NatL-o>NatL-o>NatL = lfn
    a:NatL, b:NatL =o> {
        match a {
            $zero(m) -> m; b
            |
            $succ(m) -> $succ(ladd(m)(b))
        }
    };
ladd(nl2)(nl1);;

type NODE = (int, LIST);
type LIST = union { #nil: (), #cons: NODE };
let l0:LIST = #nil (());
let l1:LIST = #cons ((2,l0));
let l2:LIST = #cons ((3,l1));
let size:LIST->int = fn
    l:LIST => {
        match l {
            #nil(_) -> 0
            |
            #cons(n) -> 1 + size(snd(n))
        }
    };
let concat:(l1:LIST)->(l2:LIST)->(ln:LIST, (size(ln) = (size(l1) + size(l2)) : int)) = fn
    l1:LIST, l2:LIST => {
        match l1 {
            #nil(_) -> (l2, refl)
            |
            #cons(n) -> (#cons( (fst(n), concat(snd(n))(l2)) ), refl)
        }
    };
concat(l1)(l2);;
