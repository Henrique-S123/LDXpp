let p:(z:Nat, (z=add(n2)(n1):Nat)) = (n2, refl); p;;

type Nat = union { #zero: (), #succ: Nat };
let n0 = #zero(());
let n1 = #succ(n0);
let n2 = #succ(n1);
let n3 = #succ(n2);
let add:Nat->Nat->Nat =
    fn a:Nat, b:Nat => {
        match a {
            #zero(m) -> m; b
            |
            #succ(m) -> #succ(add(m)(b))
        }
    };
let p:(z:Nat, (z=add(n1)(n1):Nat)) = (n2, refl); p;;

type NODE = (int, LIST);
type LIST = union { #nil: (), #cons: NODE };
let l0:LIST = #nil (());
let l1:LIST = #cons ((2,l0));
let l2:LIST = #cons ((3,l1));
let size:LIST->int = fn
    l:LIST => {
        match l {
            #nil(_) -> 0
            |
            #cons(n) -> 1 + size(snd(n))
        }
    };
let concat:(la:LIST)->(lb:LIST)->(ln:LIST, (size(ln) = (size(la) + size(lb)) : int)) = fn
    la:LIST, lb:LIST => {
        match la {
            #nil(_) -> (lb, refl)
            |
            #cons(n) -> (#cons( (fst(n), concat(snd(n))(lb)) ), refl)
        }
    };
let p:(z:LIST, (size(z)=size(concat(l0)(l2)):int)) = (l2, refl); p;;

type NODE = (int, LIST);
type LIST = union { #nil: (), #cons: NODE };
let l0:LIST = #nil (());
let l1:LIST = #cons ((2,l0));
let l2:LIST = #cons ((3,l1));
let size:LIST->int = fn
    l:LIST => {
        match l {
            #nil(_) -> 0
            |
            #cons(n) -> 1 + size(snd(n))
        }
    };
let concat:(l1:LIST)->(l2:LIST)->(ln:LIST, (size(ln) = (size(l1) + size(l2)) : int)) = fn
    l1:LIST, l2:LIST => {
        match l1 {
            #nil(_) -> (l2, refl)
            |
            #cons(n) -> (#cons( (fst(n), concat(snd(n))(l2)) ), refl)
        }
    };
concat(l0)(l2);;

