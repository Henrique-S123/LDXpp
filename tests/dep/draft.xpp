let splitlist:(n:Nat)->(a:LIST)->(b:LIST, c:LIST, (fst(concat(b)(c)) = a : LIST)) =
    fn n:Nat, a:LIST => {
        match n {
            #zero(m) -> m; (#nil(()), a, refl)
            |
            #succ(ns) ->
                match a {
                    #nil(m) -> m; (#nil(()), #nil(()), refl)
                    |
                    #cons(n) ->
                        let val = fst(n); let rest = snd(n);
                        let res = splitlist(ns)(rest);
                        let rb = fst(res); let rc = fst(snd(res)); let eihl = snd(snd(res));
                        leteq e = eihl;
                        let nrb = #cons((val, rb));
                        (nrb, rc, hyp)
                }
        }
    };
splitlist(n1)(l2);;
