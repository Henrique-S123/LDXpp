let concat:(la:LIST)->(lb:LIST)->(ln:LIST, (size(ln) = add(size(la))(size(lb)) : Nat)) =
    fn la:LIST, lb:LIST => {
        match la {
            #nil(m) -> m; (lb, refl)
            |
            #cons(n) ->
                let res = concat(snd(n))(lb);
                leteq e1 = snd(res);
                let newpair = (fst(n), fst(res));
