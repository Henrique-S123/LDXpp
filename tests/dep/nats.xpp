type Nat = union { #zero: (), #succ: Nat };
let n0 = #zero(());
let n1 = #succ(n0);
let n2 = #succ(n1);
let add:Nat->Nat->Nat =
    fn a:Nat, b:Nat => {
        match a {
            #zero(m) -> m; b
            |
            #succ(m) -> #succ(add(m)(b))
        }
    };
add(n2)(n1);;

type Nat = union { #zero: (), #succ: Nat };
let n0 = #zero(());
let n1 = #succ(n0);
let n2 = #succ(n1);
let n3 = #succ(n2);
let add:Nat->Nat->Nat =
    fn a:Nat, b:Nat => {
        match a {
            #zero(m) -> m; b
            |
            #succ(m) -> #succ(add(m)(b))
        }
    };
let p:(z:Nat, (z=add(n2)(n1):Nat)) = (n3, refl); p;;

